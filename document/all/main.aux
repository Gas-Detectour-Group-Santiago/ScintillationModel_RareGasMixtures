\newlabel{fig:GEM}{{49}{42}{Predicción del centelleo secundario visible e infrarrojo de $\Ar -\CF _4$ para condiciones representativas de una geometría tipo GEM. La banda refleja la variación asociada a los parámetros efectivos $P_{\Ar ^{**}}$ y a la producción directa de especies emisoras de CF$_4$/CF$_3$}{figure.caption.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {50}{\ignorespaces Predicción del centelleo secundario visible e infrarrojo de $\mathrm  {Ar}-\mathrm  {CF}_4$ para condiciones representativas de una geometría tipo TH-GEM. La mayor longitud efectiva de avalancha favorece un incremento del rendimiento óptico frente a estructuras más finas.}}{43}{figure.caption.27}\protected@file@percent }
\newlabel{fig:th-GEM}{{50}{43}{Predicción del centelleo secundario visible e infrarrojo de $\Ar -\CF _4$ para condiciones representativas de una geometría tipo TH-GEM. La mayor longitud efectiva de avalancha favorece un incremento del rendimiento óptico frente a estructuras más finas}{figure.caption.27}{}}
