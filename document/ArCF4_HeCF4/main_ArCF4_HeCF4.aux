\@writefile{lof}{\contentsline {figure}{\numberline {28}{\ignorespaces Predicción del centelleo secundario visible de $\mathrm  {Ar}-\mathrm  {CF}_4$ comparada con datos experimentales. Los puntos cerrados representan estimaciones indirectas y los puntos abiertos estimaciones directas. La banda muestra la variación asociada a los esquemas de parámetros considerados para la extrapolación al secundario.}}{26}{figure.caption.13}\protected@file@percent }
\newlabel{fig:ArCF4_sec_VIS}{{28}{26}{Predicción del centelleo secundario visible de $\Ar -\CF _4$ comparada con datos experimentales. Los puntos cerrados representan estimaciones indirectas y los puntos abiertos estimaciones directas. La banda muestra la variación asociada a los esquemas de parámetros considerados para la extrapolación al secundario}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {29}{\ignorespaces Predicción del centelleo secundario en $\mathrm  {He}-\mathrm  {CF}_4$. Al no existir transferencia energética desde el gas noble hacia el CF$_4$ en el rango espectral estudiado, esta comparación constituye una prueba directa de los parámetros asociados a la emisión propia del CF$_4$.}}{27}{figure.caption.14}\protected@file@percent }
\newlabel{fig:HeCF4_sec_VIS}{{29}{27}{Predicción del centelleo secundario en $\He -\CF _4$. Al no existir transferencia energética desde el gas noble hacia el CF$_4$ en el rango espectral estudiado, esta comparación constituye una prueba directa de los parámetros asociados a la emisión propia del CF$_4$}{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {30}{\ignorespaces Predicción del centelleo secundario ultravioleta en mezclas con CF$_4$. La descripción es razonable en el régimen de operación principal, aunque a baja presión el esquema de umbrales pierde validez y la predicción se vuelve menos robusta.}}{28}{figure.caption.15}\protected@file@percent }
\newlabel{fig:LIP_UV}{{30}{28}{Predicción del centelleo secundario ultravioleta en mezclas con CF$_4$. La descripción es razonable en el régimen de operación principal, aunque a baja presión el esquema de umbrales pierde validez y la predicción se vuelve menos robusta}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {31}{\ignorespaces Predicción del centelleo secundario infrarrojo cercano de $\mathrm  {Ar}-\mathrm  {CF}_4$. En este caso no se realiza un reajuste específico al secundario: la banda procede directamente de la propagación de las incertidumbres estadísticas y sistemáticas del ajuste primario IR.}}{28}{figure.caption.16}\protected@file@percent }
\newlabel{fig:ArCF4_sec_IR}{{31}{28}{Predicción del centelleo secundario infrarrojo cercano de $\Ar -\CF _4$. En este caso no se realiza un reajuste específico al secundario: la banda procede directamente de la propagación de las incertidumbres estadísticas y sistemáticas del ajuste primario IR}{figure.caption.16}{}}
