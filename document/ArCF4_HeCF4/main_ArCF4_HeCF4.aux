\newlabel{fig:GEM}{{32}{30}{Predicción del centelleo secundario visible e infrarrojo de $\Ar -\CF _4$ para condiciones representativas de una geometría tipo GEM. La banda refleja la variación asociada a los parámetros efectivos $P_{\Ar ^{**}}$ y a la producción directa de especies emisoras de CF$_4$/CF$_3$}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {33}{\ignorespaces Predicción del centelleo secundario visible e infrarrojo de $\mathrm  {Ar}-\mathrm  {CF}_4$ para condiciones representativas de una geometría tipo TH-GEM. La mayor longitud efectiva de avalancha favorece un incremento del rendimiento óptico frente a estructuras más finas.}}{31}{figure.caption.18}\protected@file@percent }
\newlabel{fig:th-GEM}{{33}{31}{Predicción del centelleo secundario visible e infrarrojo de $\Ar -\CF _4$ para condiciones representativas de una geometría tipo TH-GEM. La mayor longitud efectiva de avalancha favorece un incremento del rendimiento óptico frente a estructuras más finas}{figure.caption.18}{}}
